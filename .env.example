# =========================================================================
#  jitu-nath backend — environment template
#  Copy to `.env` and fill in real values.  `.env` is git-ignored.
# =========================================================================

# --- Runtime -------------------------------------------------------------
NODE_ENV=production
PORT=5000

# --- Database ------------------------------------------------------------
DATABASE_URL=

# --- JWT -----------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=365d

# --- Password hashing ----------------------------------------------------
BCRYPT_SALT_ROUND=12

# --- CORS ----------------------------------------------------------------
# Comma-separated list of extra allowed frontend origins.
CORS_ORIGINS=

# --- Stripe (optional) ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (SMTP) --------------------------------------------------------
EMAIL_FROM=
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=
EMAIL_PORT=587
